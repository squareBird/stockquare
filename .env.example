# Stockquare Backend — Environment Variables
# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# ---------------------------------------------------------------------------
# KIS Open API credentials (REQUIRED for trading endpoints)
# Issue a key pair at https://apiportal.koreainvestment.com → 개인 서비스 신청
# ---------------------------------------------------------------------------

# KIS-issued App Key (required for all KIS calls)
KIS_APP_KEY=your_app_key_here

# KIS-issued App Secret (required for all KIS calls)
KIS_APP_SECRET=your_app_secret_here

# KIS 계좌번호 앞 8자리 (예: "12345678-01" 에서 앞 부분 "12345678")
# Required for /account-summary. Watchlist works without it.
KIS_ACCOUNT_NO=12345678

# KIS 계좌 상품 코드 2자리 (예: "12345678-01" 에서 뒷 부분 "01")
# Typical value: "01" for domestic cash account
KIS_ACCOUNT_PRODUCT_CODE=01

# Account mode — `mock` (모의투자) or `real` (실전투자)
# Start with `mock` for safety; switch to `real` only when credentials are verified.
KIS_ACCOUNT_MODE=mock

# ---------------------------------------------------------------------------
# KIS Open API — optional (Phase 2)
# ---------------------------------------------------------------------------

# HTS ID — reserved for Phase 2 WebSocket real-time streaming. Leave blank in Phase 1.
KIS_HTS_ID=

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# SQLAlchemy async URL.
# - Docker compose (Postgres): postgresql+asyncpg://stockquare:stockquare@postgres:5432/stockquare
# - Local sqlite fallback:      sqlite+aiosqlite:///./stockquare.db
DATABASE_URL=postgresql+asyncpg://stockquare:stockquare@postgres:5432/stockquare

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------

# Comma-separated list of allowed browser origins for cross-origin fetches.
# The Next.js dev/prod UI runs on http://localhost:3000 by default.
# Example for multiple origins: CORS_ORIGINS=http://localhost:3000,https://stockquare.app
CORS_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------

# Runtime environment — `development` or `production`.
# In non-development environments, startup logs WARN for missing KIS credentials.
APP_ENV=development

# Python logging level — DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
